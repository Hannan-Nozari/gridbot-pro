FROM node:20-alpine

WORKDIR /app

# Build args for API URLs baked into the bundle
ARG NEXT_PUBLIC_API_URL=https://tradinix.com/api/v1
ARG NEXT_PUBLIC_WS_URL=wss://tradinix.com/ws
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_WS_URL=$NEXT_PUBLIC_WS_URL

COPY package*.json ./
RUN npm ci

COPY . .

RUN npm run build

EXPOSE 3000

ENV HOSTNAME=0.0.0.0
ENV PORT=3000

CMD ["npm", "start"]
